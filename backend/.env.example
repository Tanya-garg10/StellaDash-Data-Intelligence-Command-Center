# ========================================
# StellaDash Backend Environment Variables
# ========================================

# Copy this file to .env and fill in your values
# cp .env.example .env

# ========================================
# GEMINI AI (Optional - for AI Chat feature)
# ========================================
# Get your free API key from: https://makersuite.google.com/app/apikey
# Leave empty to disable AI chat feature
GEMINI_API_KEY=
# Alternative: GOOGLE_API_KEY also works
# GOOGLE_API_KEY=

# ========================================
# AWS S3 (Optional - for cloud storage)
# ========================================
# Get credentials from AWS Console → IAM
# Leave empty to disable S3 upload feature
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=stelladash-uploads
AWS_REGION=us-east-1

# ========================================
# NOTES
# ========================================
# - App works perfectly without any API keys
# - AI Chat and S3 are optional features
# - Never commit .env file to git (already in .gitignore)
# - Keep your API keys secure and private
