# ========================================
# StellaDash - Complete Environment Setup
# ========================================

# This is a master reference file showing all environment variables
# Actual .env files are located in backend/ and frontend/ folders

# ========================================
# BACKEND (.env in backend/ folder)
# ========================================

# Gemini AI API Key (Optional - for AI Chat)
# Get free key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# AWS S3 Configuration (Optional - for cloud storage)
# Get from AWS Console → IAM
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=stelladash-uploads
AWS_REGION=us-east-1

# ========================================
# FRONTEND (.env.local in frontend/ folder)
# ========================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# ========================================
# SETUP INSTRUCTIONS
# ========================================

# 1. Backend Setup:
#    cd backend
#    cp .env.example .env
#    # Edit .env and add your API keys (optional)

# 2. Frontend Setup:
#    cd frontend
#    cp .env.example .env.local
#    # Usually no changes needed

# 3. Start Application:
#    # Terminal 1 (Backend):
#    cd backend && uvicorn app:app --reload
#    
#    # Terminal 2 (Frontend):
#    cd frontend && npm run dev

# ========================================
# IMPORTANT NOTES
# ========================================
# ✅ App works perfectly WITHOUT any API keys
# ✅ AI Chat and S3 are optional features
# ✅ Never commit .env files to git
# ✅ Keep API keys secure and private
# ✅ Free tier available for both Gemini and AWS
