# ========================================
# StellaDash Frontend Environment Variables
# ========================================

# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ========================================
# API Configuration
# ========================================
# Backend API URL (default: http://localhost:8000)
NEXT_PUBLIC_API_URL=https://stelladash-backend.onrender.com

# ========================================
# NOTES
# ========================================
# - Frontend works with default settings
# - Only change API_URL if backend runs on different port
# - .env.local is automatically ignored by git
